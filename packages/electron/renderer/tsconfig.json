{
  "extends": "../../../tsconfig.base.json",
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "jsx": "react-jsx",
    "isolatedModules": true,
    "noEmit": true,
    "strict": true,
    "paths": {
      "@glance/shared": ["../../shared/src/index.ts"]
    }
  },
  "include": ["src/**/*", "*.ts", "*.tsx"]
}
